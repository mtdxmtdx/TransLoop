{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TransLoop",
  "version": "0.1.0",
  "identifier": "com.transloop.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TransLoop · 设置",
        "url": "index.html",
        "width": 760,
        "height": 640,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "visible": true,
        "center": true
      },
      {
        "label": "popup",
        "title": "TransLoop Popup",
        "url": "popup.html",
        "width": 380,
        "height": 220,
        "minWidth": 240,
        "minHeight": 140,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false,
        "focus": false,
        "shadow": false
      },
      {
        "label": "overlay",
        "title": "TransLoop Overlay",
        "url": "overlay.html",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": true,
        "shadow": false
      },
      {
        "label": "capture",
        "title": "TransLoop · 截图翻译",
        "url": "capture.html",
        "width": 520,
        "height": 460,
        "minWidth": 360,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false,
        "focus": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
