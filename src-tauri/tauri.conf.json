{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TransLoop",
  "version": "1.0.2",
  "identifier": "com.transloop.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TransLoop",
        "url": "index.html",
        "width": 760,
        "height": 640,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "visible": false,
        "center": true
      },
      {
        "label": "popup",
        "title": "TransLoop Popup",
        "url": "popup.html",
        "width": 380,
        "height": 220,
        "minWidth": 240,
        "minHeight": 140,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false,
        "focus": false,
        "shadow": false
      },
      {
        "label": "overlay",
        "title": "TransLoop Overlay",
        "url": "overlay.html",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "focus": true,
        "shadow": false
      },
      {
        "label": "capture",
        "title": "TransLoop · 截图翻译",
        "url": "capture.html",
        "width": 520,
        "height": 460,
        "minWidth": 360,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false,
        "focus": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; connect-src ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; frame-src 'none'; child-src 'none'; form-action 'none'",
      "devCsp": "default-src 'self' http://localhost:1420; script-src 'self' 'unsafe-eval' http://localhost:1420; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; connect-src ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; frame-src 'none'; child-src 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
